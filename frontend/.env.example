# ============================================================
# Frontend Environment Variables — TEMPLATE
# Copy file này thành .env và chỉnh lại cho phù hợp môi trường
# ============================================================

# Port của Vite dev server
VITE_PORT=5173

# URL của API Gateway (dùng cho proxy trong vite.config.ts)
VITE_GATEWAY_URL=http://localhost:8080

# Base path của API (dùng trong axios client)
VITE_API_BASE_URL=/api/v1

# Timeout mỗi request (ms)
VITE_API_TIMEOUT=30000
